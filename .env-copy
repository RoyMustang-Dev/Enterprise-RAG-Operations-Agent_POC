# -----------------------------------------------------------------------------
# Production-Ready Environment Template (.env-copy)
# -----------------------------------------------------------------------------
# Copy this file to .env and fill values.
# All variables below are referenced in code. Each block includes usage notes.

# =====================
# 1) Core Provider Routing
# =====================

# Explicitly define which LLM provider handles which capability.
# Options: modelslab, groq, gemini, anthropic, openai, sarvam, ollama

# Specifies the primary LLM provider used for core RAG synthesis and logical reasoning tasks.
CORE_LLM_PROVIDER=

# Specifies the LLM provider used when visual capabilities, image analysis, and multimodal reasoning are required.
VISION_LLM_PROVIDER=

# Specifies the LLM provider to handle audio-centric generations and fast transcription (e.g., ModelsLab for TTS/STT).
AUDIO_LLM_PROVIDER=

# =====================
# 2) Provider API Keys
# =====================
# Primary routing prefers ModelsLab + Gemini when keys exist.

# The API key for ModelsLab, used for high-speed generative synthesis, embeddings, and Enterprise TTS/STT hooks.
MODELSLAB_API_KEY=

# The API key for Google Gemini, used natively for deep reasoning, dual-plane embeddings, and intensive visual processing.
GEMINI_API_KEY=

# Groq is used as fallback for routing and guardrails if paid keys are missing.

# The API key for Groq, specifically leveraged for ultra-fast Llama Guard intent routing and safety validation.
GROQ_API_KEY=

# Optional (future expansion): only needed if you wire these providers explicitly.

# The API key for Sarvam, primarily used for enterprise-grade Indic language dialect translation and generation.
SARVAM_API_KEY=

# The API key for OpenAI, used globally if routing distinct RAG execution nodes through the advanced GPT ecosystem.
OPENAI_API_KEY=

# The API key for Anthropic, used if delegating complex coding generation agents through the Claude model architecture.
ANTHROPIC_API_KEY=

# Local Model HuggingFace Token (Optional)

# The HuggingFace Hub token needed to securely authenticate and download gated open-source models (like Llama-3) to local VRAM.
HF_TOKEN=

# How to get keys:
# - ModelsLab: https://modelslab.com/ (Dashboard -> API Keys)
# - Gemini: https://aistudio.google.com/ (API Key)
# - Groq: https://console.groq.com/ (API Keys)
# - Sarvam: https://www.sarvam.ai/ (API Keys)

# =====================
# 3) Qdrant Vector Store
# =====================
# You can acquire these from Qdrant Cloud (cloud.qdrant.io). Create a cluster and copy the URL and API Key.

# The main URL endpoint where your Qdrant Vector Database is hosted (applicable to both Cloud or Local deployments).
QDRANT_URL=

# The secure cryptographic API key securely mapping to the target Qdrant cluster to authorize high-speed vector read/write throughput.
QDRANT_API_KEY=

# Multi-tenant routing: when true, tenant_id is applied as a payload filter.

# Boolean flag enabling strict payload separation between different users or discrete client organizations inside a unified vector index.
QDRANT_MULTI_TENANT=true

# Default collection if tenant_id is not provided.

# The fallback global namespace collection instantiated inside Qdrant when no explicitly scoped or strict tenant ID is supplied.
QDRANT_COLLECTION=enterprise_rag

# =====================
# 4) Celery + Redis
# =====================
# Used for background crawling & heavy ingestion tasks. 
# Get these connections by spinning up a local Redis container or using RedisLabs mapped instances.

# Boolean flag to explicitly enable or disable the Celery-based Redis asynchronous background worker array layer.
CELERY_ENABLED=true

# The explicit Redis connection string URL leveraged by Celery to queue and autonomously orchestrate sprawling asynchronous tasks.
CELERY_BROKER_URL=

# The explicit Redis connection string URL utilized by Celery exclusively to store and cache the final execution payloads of crawler jobs.
CELERY_RESULT_BACKEND=

# Boolean flag instructing external bash/powershell bootstrapper hooks to automatically spin up a Celery worker alongside the API.
CELERY_AUTOSTART=true

# =====================
# 5) Uploads + Ephemeral Sessions
# =====================
# Controls how large file uploads can be and how long ephemeral sessions live in Qdrant.

# The maximum absolute file payload size allowed natively for direct uploads onto the `/api/v1/chat` physical endpoint (measured in MB).
MAX_UPLOAD_MB=20

# The physical lifespan duration (in hours) assigned to temporary isolated Qdrant session vector collections spawned purely by live user tracking IDs.
EPHEMERAL_TTL_HOURS=24

# The frequency interval (in minutes) governing how often the RAG cleanup daemon aggressively sweeps and wipes expired conversational namespace vectors.
EPHEMERAL_CLEANUP_INTERVAL_MINUTES=60

# =====================
# 6) RAG Retrieval Controls
# =====================

# Boolean flag that enables aggressive LLM-driven cross-encoder reranking algorithms executing over conventionally retrieved semantic chunks.
RERANKER_ENABLED=true

# Dictates the specific Cross-Encoder or fast sequence LLM effectively utilized to dynamically re-score preliminary array results (e.g., Llama-3.1).
RERANKER_MODEL_NAME=llama-3.1-8b-instant

# Defines the total absolute absolute maximum threshold of highly ranked dense chunks appended to the LLM synthesis generation sequence matrix.
RERANK_TOP_K=5

# Boolean flag to explicitly enable dual-plane sparse-dense hybrid search mechanisms (integrating traditional BM25 scoring alongside vector embeddings).
HYBRID_SEARCH=true

# =====================
# 7) Prompt / Persona Controls
# =====================
# Persona injection modes: strict | all

# Determines whether the globally bootstrapped instruction persona propagates strictly inside default routing or forcibly binds to 'all' modular sub-agents.
PERSONA_INJECTION_MODE=strict

# The absolute maximum character length parameter assigned strictly to the unified persona bootstrap sequence mitigating unintended system context dilution.
PERSONA_MAX_CHARS=4000

# Trims fragmented, localized, or conditionally injected persona sub-strings down uniformly to fit this character constraint threshold logic.
PERSONA_PARTIAL_MAX_CHARS=800

# Aggressively limits dynamic, heuristically loaded few-shot prompting examples preventing unexpected prompt context token boundary violations.
FEW_SHOT_MAX_CHARS=2500

# =====================
# 8) Guard Settings
# =====================

# Boolean flag mapping strictly to draconian execution halting mechanisms triggered anytime the Prompt Guard identifies potential edge-case suspicious behavioral queries.
GUARD_STRICT=false

# Boolean flag dictating exactly whether approved soft-allow benign linguistic phrases safely skip standard restrictive Llama-Guard filtering layers.
GUARD_SOFT_ALLOW=true

# An explicit comma-separated physical array containing highly recurrent benign instructions structurally bypassed from aggressive malicious intent heuristic checks.
GUARD_SOFT_ALLOW_PHRASES=summarize,summary,read the text,extract text,ocr,describe the image,what is in the image,list the text

# A stringent secondary keyword-lock boundary array preventing prompt injections explicitly mimicking or obfuscated alongside permitted soft-allow phrasing overrides.
GUARD_SOFT_ALLOW_RISKY_PHRASES=ignore previous,system prompt,developer message,jailbreak,exfiltrate,bypass,override,policy

# =====================
# 9) Vision + OCR
# =====================

# Configures the overarching internal visual routing heuristics fallback matrix natively (switching fluidly across 'auto', 'ocr', 'vision', 'BLIP', or 'LLaVA').
VISION_BACKEND=auto

# Defines the internal safety floor of absolute available target GPU VRAM (in Gigabytes) needed natively to safely trigger an integrated local PyTorch LLaVA invocation.
VISION_LLAVA_MIN_VRAM_GB=8

# Explicitly configures the dedicated physical HuggingFace endpoint or locally quantified network file path utilized universally for the core spatial vision network backend.
VISION_MODEL_NAME=Salesforce/blip-image-captioning-base

# Pre-configures a highly quantified or computationally smaller target Vision Backend framework instantly launched if the primary spatial model crashes or throws out OOM exceptions.
VISION_FALLBACK_MODEL=Salesforce/blip-image-captioning-base

# Boolean flag natively enabling the entire logic cascade allowing intensive visual pipelines to sequentially degrade toward purely lower-tier extraction mechanisms without application failures.
VISION_ALLOW_FALLBACK=true

# Sets the internal PyTorch optical character recognition processing backend array explicitly applied parsing heavily image-based file boundaries (defaults to 'easyocr').
OCR_ENGINE=easyocr

# Defines the root internal character syntax target for the physical OCR toolkit governing exclusively which native linguistic alphabet symbols its layout recognizes dynamically.
OCR_LANG=en

# Failsafe structural metric designating minimum string lengths; dynamically enforcing reroute logic on pure PyMuPDF text blocks sliding backwards towards optical text isolation if missing metrics.
PDF_OCR_MIN_CHARS=30

# Boolean flag dictating strictly that the extraction logic safely loops backward falling onto optical isolation passes natively whenever direct semantic PyMuPDF scraping loops critically fail internally.
PDF_OCR_FALLBACK=true

# =====================
# 10) STT / TTS
# =====================
# If MODELSLAB_API_KEY exists, STT/TTS routes to ModelsLab automatically.
# Fallback for STT: local whisper (when STT_BACKEND=local)

# Dictates the intrinsic localized Speech-to-Text inference execution architecture actively polling logic on user audio payloads strictly via locally cached 'whisper' binaries or direct cloud APIs.
STT_BACKEND=local

# Boolean flag structurally wired into the primary API routing module explicitly allowing or blocking physical access calls specifically targeting the public endpoints handling data transcriptions.
ENABLE_TRANSCRIBE=true

# =====================
# 11) Model Cache / Preload
# =====================
# Centralized directory to cache HuggingFace artifacts & prevent symlink bugs.

# Maps effectively to the explicitly centralized file logic structural location where PyTorch / HuggingFace intrinsically caches and locks massive target multi-gigabyte open-source artifacts safely offline.
MODEL_CACHE_DIR=

# Environmental execution pipeline parameter explicitly shielding internal node interactions forcing underlying systems off dangerous, non-standard, and unsafe cache file Symlink propagation implementations on OS drives.
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Boolean flag instructing structural DAG initialization logic forcing the system explicitly pushing required large local logic node structural models actively inside active server VRAM uniformly upon primary endpoint process instantiation hooks.
PRELOAD_MODELS=false

# Auto-fix system deps (Windows only). Installs VC++ Redistributable and reinstalls torch if needed.

# Boolean wrapper triggering deep internal execution hooks explicitly monitoring background Windows environments specifically looking out for and diagnosing C++ or Native DLL conflicts while intelligently auto-healing Python environment targets securely when failures strike.
AUTO_FIX_SYSTEM_DEPS=true

# =====================
# 12) CORS & Observability
# =====================

# Explicit comma-separated URL logic string natively whitelisting specifically explicitly approved specific external domain origin URLs dynamically allowing direct execution permissions across HTTP logic layers securely avoiding preflight isolation restrictions dynamically.
CORS_ALLOW_ORIGINS=

# Boolean tracking parameter toggling explicitly whether isolated network structural execution responses legally enable browsers binding and transferring implicit authentication headers and encrypted target local storage payload configurations securely locally.
CORS_ALLOW_CREDENTIALS=false

# Boolean flag defining universal system mapping instructing the backend completely encapsulating deep telemetry metrics seamlessly pushing runtime output diagnostics internally into decoupled OpenTelemetry observability endpoints globally autonomously aggregating application metrics sequentially.
OTEL_ENABLED=true

# =====================
# 13) Crawler Variables
# =====================
# Optional: proxy list for WebCrawling (comma separated string). Leave empty if not using a proxy provider.

# Native configuration sequence string directly feeding autonomous headless Playwright structural web spiders explicit explicit targeted rotating HTTPS SOCKS5 endpoints safely insulating the crawler logic completely obfuscating structural host traffic identities against geographical blocking filters completely.
CRAWLER_PROXY_URLS=


TENANT_DB_TTL_DAYS=30 #tenant db clear after 30 days
TENANT_DB_CLEANUP_INTERVAL_HOURS=168 # checks once a week

# =====================
# 14) Data Analytics Agent (Advanced APIs)
# =====================

# Google Cloud OAuth JSON Dictionary (Required for GA4 & Google Sheets)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Salesforce Account Credentials (Required for natively querying CRM SOQL objects)
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# Stripe Production/Test Key (Required for fetching financial customer and revenue entity arrays)
STRIPE_API_KEY=

# Microsoft Azure Active Directory Credentials (Required for proxying DAX aggregations against Power BI semantic models)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
